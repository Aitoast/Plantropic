# ── 필수 ─────────────────────────────────────────────
# 운영에서는 반드시 길고 랜덤한 값으로 설정(토큰 서명 키).
JWT_SECRET=change-me-to-a-long-random-string

# ── 선택: 실제 DB ────────────────────────────────────
# 비워두면 인메모리 저장소로 구동됩니다(재시작 시 데이터 소멸).
# 설정하면 PostgreSQL 을 사용합니다:  npm i pg  후  psql "$DATABASE_URL" -f schema.sql
# DATABASE_URL=postgres://user:pass@localhost:5432/planora

# 웹 오리진(CORS + OAuth 리다이렉트 기본값)
WEB_ORIGIN=http://localhost:5173
PORT=4000

# ── 선택: 소셜 로그인 ────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback
# KAKAO_CLIENT_ID=
# KAKAO_REDIRECT_URI=http://localhost:4000/api/auth/kakao/callback

# ── AI 에이전트 (선택) ─────────────────────────────
# 키가 없으면 규칙 기반으로만 동작(자동 폴백). 넣으면 LLM 판단/문장 생성 활성화.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-8      # 비용 절감: claude-haiku-4-5
# TZ=Asia/Seoul                        # 서버 시간대 고정(패턴 시각 정확도)

# ── 알림/스케줄러 (선택) ─────────────────────────────
# 채널(디스코드/슬랙 웹훅, 카카오 토큰, Expo 푸시토큰)은 유저별로
# PUT /api/notify/settings 로 저장합니다 (.env 아님).
# PREP_MINUTES=30              # 이동알림: 준비시간(분)
# TRANSIT_ALERT_MIN=10         # 이동알림: 이 분 이상 걸릴 때만
# SCHEDULER_INTERVAL_SEC=60    # 알림 틱 간격(초)
# SLACK_VERIFY_TOKEN=          # 슬랙 인바운드 웹훅 검증 토큰(선택)

# ── 지도 API (이동시간 계산) ─────────────────────────
# KAKAO_REST_API_KEY=          # 필수(지오코딩). developers.kakao.com
# ODSAY_API_KEY=               # 선택(대중교통 실측). 없으면 직선거리 근사

# ── 인박스 게이팅 (유지비용·남용 방지) ───────────────
# INBOX_WINDOW_MIN=15    # 알림 후 이 분 동안 LLM 신규등록 허용(A)
# INBOX_DAILY_MAX=12     # 창 밖에서 하루 허용 횟수(B). 확인·미루기는 무제한(D)
# INBOX_MAX_LEN=200      # 입력 길이 상한(E)
