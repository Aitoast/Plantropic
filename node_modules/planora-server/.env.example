# ── 필수 ─────────────────────────────────────────────
# 운영에서는 반드시 길고 랜덤한 값으로 설정(토큰 서명 키).
JWT_SECRET=change-me-to-a-long-random-string

# ── 선택: 실제 DB ────────────────────────────────────
# 비워두면 인메모리 저장소로 구동됩니다(재시작 시 데이터 소멸).
# 설정하면 PostgreSQL 을 사용합니다:  npm i pg  후  psql "$DATABASE_URL" -f schema.sql
# DATABASE_URL=postgres://user:pass@localhost:5432/planora

# 웹 오리진(CORS + OAuth 리다이렉트 기본값)
WEB_ORIGIN=http://localhost:5173
PORT=4000

# ── 선택: 소셜 로그인 ────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback
# KAKAO_CLIENT_ID=
# KAKAO_REDIRECT_URI=http://localhost:4000/api/auth/kakao/callback
